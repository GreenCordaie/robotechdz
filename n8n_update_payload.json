        "jsonBody": "={\n  \"chat_id\": \"{{ $json.body.config.tg_caisse }}\",\n  \"text\": \"🛒 *Nouvelle Commande #{{ $json.body.data.orderNumber }}*\\n\\n👤 Client: {{ $json.body.data.customer }}\\n📱 Tél: {{ $json.body.data.customerPhone }}\\n💰 Total: {{ $json.body.data.total }} DZD\\n📦 Articles: {{ $json.body.data.itemsCount }}\\n🔗 {{ $json.body.data.link }}\",\n  \"parse_mode\": \"Markdown\"\n}",
        "options": {}
      },
